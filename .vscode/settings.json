{
  "vitest.enable": true,
  "vitest.commandLine": "npx vitest",
  "js/ts.validate.enable": true,
  "js/ts.implicitProjectConfig.experimentalDecorators": true,
  "eslint.validate": ["typescript", "typescriptreact"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#35b2c5",
    "activityBar.background": "#35b2c5",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#f8e6f6",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#35b2c5",
    "statusBar.background": "#2a8e9d",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#35b2c5",
    "statusBarItem.remoteBackground": "#2a8e9d",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#2a8e9d",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#2a8e9d99",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#2a8e9d"
}
