#!/usr/bin/env bash

set -e

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Change to the extension directory
cd "$SCRIPT_DIR"

# Check if Node.js is available
if ! command -v node >/dev/null 2>&1; then
    echo "Error: Node.js is required but not installed."
    echo "Please install Node.js (v22.19.0+ or v24+) and try again."
    exit 1
fi

# Check Node.js version meets minimum requirement (^22.19.0 || >=24)
NODE_VERSION=$(node -v | sed 's/^v//')
NODE_MAJOR=$(echo "$NODE_VERSION" | cut -d. -f1)
NODE_MINOR=$(echo "$NODE_VERSION" | cut -d. -f2)

VERSION_OK=false
if [ "$NODE_MAJOR" -ge 24 ]; then
    VERSION_OK=true
elif [ "$NODE_MAJOR" -eq 22 ] && [ "$NODE_MINOR" -ge 19 ]; then
    VERSION_OK=true
fi

if [ "$VERSION_OK" = false ]; then
    echo "Error: Node.js v${NODE_VERSION} is not supported."
    echo "This extension requires Node.js v22.19.0+ or v24+."
    echo "Please upgrade Node.js and try again: https://nodejs.org/"
    exit 1
fi

# Check if npm is available
if ! command -v npm >/dev/null 2>&1; then
    echo "Error: npm is required but not installed."
    echo "Please install npm and try again."
    exit 1
fi

# Ensure dependencies are installed
if [ ! -d "$SCRIPT_DIR/node_modules" ]; then
    echo "Installing extension dependencies..."
    cd "$SCRIPT_DIR"
    npm install --production --silent
fi

# Check if the bundled script exists, build if needed
if [ ! -f "$SCRIPT_DIR/dist/index.js" ]; then
    echo "Building extension..."
    cd "$SCRIPT_DIR"
    
    # Install dev dependencies for building
    npm install --silent
    
    # Build the extension
    npm run build --silent
    
    if [ ! -f "$SCRIPT_DIR/dist/index.js" ]; then
        echo "Error: Failed to build extension"
        exit 1
    fi
fi

# Execute the Node.js script with all arguments passed through
exec node "$SCRIPT_DIR/dist/index.js" "$@"